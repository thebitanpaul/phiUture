# ============================================
# phiUture — environment variables
# ============================================
# Copy this file to ".env" and fill in values.
# Only variables prefixed with VITE_ are exposed to the app.

# Live content updates without a redeploy.
# --------------------------------------------
# All editable content lives in JSON files under public/data/
# (products.json, music.json, skills.json, experience.json, education.json).
#
# Point this at the RAW GitHub URL of that folder. The site will fetch
# the newest committed JSON at runtime (cache-busted), so editing a JSON
# file on GitHub updates the live site within a minute — no rebuild.
#
# Format:
#   https://raw.githubusercontent.com/<user>/<repo>/<branch>/public/data
#
# Example:
#   VITE_GITHUB_DATA_BASE="https://raw.githubusercontent.com/bitanpaul/phiuture/main/public/data"
#
# Leave unset to run purely on the bundled JSON (updates require a redeploy).
# VITE_GITHUB_DATA_BASE=""
