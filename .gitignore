# ============================================
# phiUture — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/
.pnpm-store/

# Build output
dist/
dist-ssr/
build/
*.local

# Vite / TypeScript caches
.vite/
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment variables (never commit secrets or config)
.env
.env.*
!.env.example

# Vercel
.vercel/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Misc / temp
*.tmp
*.temp
.cache/
coverage/

# Claude Code local settings
.claude/
